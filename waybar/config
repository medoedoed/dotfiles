	"on-click": "alacritty -e 'nmtui'",
	"min-length": 9
},

    "clock": {
        // "timezone": "America/New_York",
		"interval": 1,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a, %d %b, %H:%M:%S}",
		"min-length": 5,
		"click-action": "waybar-cal",

    },

    "custom/weather": {
	"format": "{}",
	"interval": 10,

	"exec": "~/.config/scripts/weather.sh",
	"tooltip": true
	},


    "pulseaudio": {
        "scroll-step": 3, // %, can be a float
        "reverse-scrolling": 1,
        "format": "{icon} {volume}%",
