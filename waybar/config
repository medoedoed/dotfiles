        "format-bluetooth-muted": "’¤Å {icon}’Ŗö {format_source}",
        "format-muted": "’¬Ć 0%",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’Ż│",
            "headset": "’Ćź",
            "hands-free": "’Ż│",
            "headset": "’Ćź",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’®Š", "’®┐", "’®Į"]
        },
        "on-click": "pavucontrol",
        "min-length": 2,
    },

    "custom/mem": {
        "format": "{}",
        "interval": 3,
        "exec": "free -h | awk '/Mem:/{printf $3}'",
        "tooltip": false,
    },

  	"sn/prev": {
		"format": "{}",
		"on-click": "playerctl previous",
	

  	},

   "backlight": {
		"scroll-step": 10, // %, can be a float
        "reverse-scrolling": 1,

        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"]
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "’Ś¦ {capacity}%",
        "format-plugged": "’ć”  {capacity}%" ,
        "format-alt": "{time} {icon} ",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },

    "tray": {
        "icon-size": 16,
        "spacing": 0
    },

	"custom/playerctl-controls": {
        "format": "Prev {} Next",
        "return-type": "json",
        "exec": "echo '{}'",
        "exec-if": "command -v playerctl",
        "on-click": "bash -c 'if [[ {0} == \"Next\" ]]; then 'playerctl next'; elif [[ {0} == \"Prev\" ]]; then playerctl previous; fi'"
    }
}
