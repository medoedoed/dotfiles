{
    "layer": "top", // Waybar at top layer
    "position": "top", 
	"margin": "0 0 0 0",
     "modules-left": ["sway/workspaces", "custom/mail", "tray", "prev", "custom/prev","custom/toggle", "custom/next", "custom/title"],
    "modules-center": ["clock","custom/weather"],
    "modules-right": ["sway/language","network", "pulseaudio", "custom/mem", "backlight", "battery"],


    //***************************
    //*  Modules configuration  *
    //***************************

    "sway/workspaces": {
        "disable-scroll": true,
        "persistent_workspaces": {
            "1": [1],
            "2": []}
    },

	"custom/prev": {
        "format": "ŌÅ«’ĖÅ",
        "exec": "echo 'Prev'",
        "on-click": "playerctl previous",
        "tooltip": false
    },
    "custom/next": {
        "format": "ŌÅŁ’ĖÅ",
        "exec": "echo 'Next'",
        "on-click": "playerctl next",
        "tooltip": false
    },

 "custom/toggle": {
        "format": "{}",
        "exec": "playerctl status | grep -q 'Playing' && echo 'ŌÅĖ’ĖÅ' || echo 'Ō¢Č’ĖÅ'",
        "on-click": "playerctl play-pause",
        "interval": 1,
        "tooltip": false,
		"min-length": 3
    },

	"custom/title": {
        "format": "{}",
        "exec": "playerctl metadata --format '{{ title }}'",
        "interval": 1,
		"max-length": 24
    },


    "sway/language": {
    "format": "{} ",
	"min-length": 5,
	"tooltip": false
    },

	"network": {
    	"interface": "wlp0s20f3",
