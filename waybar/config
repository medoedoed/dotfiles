{
    "layer": "top",
    "position": "top",
    "margin": "0 0 0 12",
    "modules-left": ["sway/workspaces", "custom/mail", "custom/prev", "custom/toggle", "custom/next", "custom/title"],
    "modules-center": ["clock", "custom/weather"],
    "modules-right": ["sway/language", "network#vpn", "network#wifi", "network#ethernet", "pulseaudio", "custom/mem", "backlight", "battery"],
	
    "sway/workspaces": {
	"disable-scroll": false,
	"all-outputs": true,
	"format": "{icon}",
	"format-icons": {
		"1": "&#xf269;",
		"2": "&#xf120;",
		"3": "&#xf0eb;",
		"4": "4",
		"5": "5",
		"9": "&#xf2c6;",
		"high-priority-named": [ "1", "2", "3", "9" ],
		"urgent": "",
		"focused": "",
		"default": ""
	}
},

    "custom/prev": {
        "format": "&#xf048;",
        "exec": "echo 'Prev'",
        "on-click": "playerctl previous",
        "tooltip": false
    },
    "custom/next": {
        "format": "&#xf051;",
        "exec": "echo 'Next'",
        "on-click": "playerctl next",
        "tooltip": false
    },

    "custom/toggle": {
        "format": "{}",
        "exec": "playerctl status | grep -q 'Playing' && echo '&#xf04c;' || echo '&#xf04b;'",
        "on-click": "playerctl play-pause",
        "interval": 1,
        "tooltip": false,
        "min-length": 3
    },

    "custom/title": {
        "format": "{}",
        "exec": "~/.config/scripts/scroll.sh",
        "max-length": 26
    },

    "sway/language": {
        "format": "[{}]",
        "min-length": 5,
        "tooltip": false
    },

    
    "network#ethernet": {
        "interface": "enp*",
        "format-ethernet": "[E]",
        "format-wifi": "",
        "format-linked": "",
        "format-disconnected": "",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },
    "network#wifi": {
        "interface": "wlp*",
        "format-ethernet": "",
        "format-wifi": "WiFi [{signalStrength}%]",
        "format-linked": "",
        "format-disconnected": "",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor",
        "min-length": 0
    },
    "network#vpn": {
        "interface": "tun0",
        "format": "[VPN]",
        "format-disconnected": "",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },

    "clock": {
        "interval": 1,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "[{:%a, %d %b, %H:%M:%S}]",
        "min-length": 5,
        "click-action": "waybar-cal",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            },
            "on-click-right": "mode"
        }
    },

    "custom/weather": {
        "format": "[{}]",
        "interval": 1,
        "exec": "~/.config/scripts/weather.sh",
        "tooltip": true
    },

    "pulseaudio": {
        "scroll-step": 10,
        "reverse-scrolling": 10,
        "format": "{icon} [{volume}%]",
        "format-bluetooth": "{volume}% {icon} BT {format_source}",
        "format-bluetooth-muted": "Muted {icon} BT {format_source}",
        "format-muted": "Muted 0%",
        "format-source": "{volume}% Mic",
        "format-source-muted": "Muted Mic",
        "format-icons": {
            "headphone": "HP",
            "hands-free": "HF",
            "headset": "HS",
            "phone": "P",
            "portable": "P",
            "car": "C",
            "default": "SP"
        },
        "on-click": "pavucontrol",
        "min-length": 2
    },

    "custom/mem": {
        "format": "[{}]",
        "interval": 3,
        "exec": "free -h | awk '/Mem:/{printf $3}'",
        "tooltip": false
    },

    "backlight": {
        "scroll-step": 10,
        "reverse-scrolling": 1,
        "format": "BL [{percent}%]",
        "format-icons": ["[B1]", "[B2]", "[B3]", "[B4]", "[B5]", "[B6]", "[B7]", "[B8]", "[B9]"]
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 20
        },
        "format": "BAT [{capacity}%]",
        "format-full": "BAT [{capacity}%]",
        "format-charging": "CH [{capacity}%]",
        "format-plugged": "P [{capacity}%]",
        "format-alt": "[{time}] B",
        "format-icons": ["[B1]", "[B2]", "[B3]", "[B4]", "[B5]"]
    },

    "tray": {
        "icon-size": 16,
        "spacing": 0
    },

    "custom/playerctl-controls": {
        "format": "Prev {} Next",
        "return-type": "json",
        "exec": "echo '{}'",
        "exec-if": "command -v playerctl",
        "on-click": "bash -c 'if [[ {0} == \"Next\" ]]; then playerctl next; elif [[ {0} == \"Prev\" ]]; then playerctl previous; fi'"
    }
}

