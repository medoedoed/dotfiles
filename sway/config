input * {
    xkb_layout "us,ru"
    # xkb_variant nodeadkeys # idk what does it do
    xkb_options "grp:alt_shift_toggle"
}

input "type:pointer" {
    tap enabled
    natural_scroll disabled
    dwt enabled
    accel_profile "flat" 
	pointer_accel 0.05
}

input "type:keyboard" {
    xkb_layout "us,ru"
    xkb_model pc105
    xkb_options "grp:alt_shift_toggle"
}

# --- TOUCHPAD ---

input "type:touchpad" {
	tap enabled
	scroll_factor 0.32
	natural_scroll enabled
	middle_emulation enabled
