# --- VARIABLES ---

# --- MODE KEY ---

set $mod Mod4

# --- DIRECTION KEYS ---

set {
	$left h
	$down j
	$up k
	$right l
}

# --- PROGRAMS ---

set {
	$term alacritty
	$browser firefox-wayland
	$launcher bemenu -combi-modi drun,ssh, -show combi
	$menu wofi --show drun -I
}

# --- FONT ---

set $font "Fira Mono Regular 14"

# --- GUI ---

#--- –≠–Ґ–Ю –†–Р–С–Ю–Ґ–Р–Х–Ґ –Ґ–Ю–Ы–ђ–Ъ–Ю –Т SWAYFX -----------------------------------------------------
	# –°–Ї—А—Г–≥–ї–µ–љ–Є—П
	corner_radius 1
	smart_corner_radius enable

	# –С–ї—О—А
	blur enable
	blur_xray off
	blur_passes 3
	blur_radius 3

	# –Ґ–Х–Э–Ш
	shadows on
	shadows_on_csd off
	shadow_blur_radius 5
	shadow_color #7c6f64

	# –Ч–∞—В–µ–Љ–љ–µ–љ–Є–µ –љ–µ–∞–Ї—В–Є–≤–љ—Л—Е –Њ–Ї–Њ–љ
	default_dim_inactive 0.01
	dim_inactive_colors.unfocused #000000FF
	dim_inactive_colors.urgent #900000FF



# --- WS NAMES ---

set 
{
	$ws1 1
	$ws2 2
	$ws3 3
	$ws4 4
	$ws5 5
	$ws6 6
	$ws7 7
	$ws8 8
	$ws9 9
	$ws10 10
}

############ INPUTS ############

# --- WALLPAPER --- 

#output * bg ~/Downloads/vg.jpg fill

# --- LAYOUT ---

input * {
    xkb_layout "us,ru"
    # xkb_variant nodeadkeys # idk what does it do
    xkb_options "grp:alt_shift_toggle"
}

input "type:pointer" {
    tap enabled
    natural_scroll disabled
    dwt enabled
    accel_profile "flat" 
	pointer_accel -0
}

# --- TOUCHPAD ---

input "type:touchpad" {
	tap enabled
	scroll_factor 0.32
	natural_scroll enabled
	middle_emulation enabled
	drag enabled
}


################################


# --- AUTOSTART ---

exec autotiling 
exec --no-startup-id telegram-desktop -autostart
exec --no-startup-id xset b off
exec dbus-daemon --session --address=unix:path=$XDG_RUNTIME_DIR/bus
exec_always killall mako
#exec wireplumber
#exec pipewire-pulse


exec firefox-wayland
assign [app_id="firefox-wayland"] workspace 1
assign [app_id=$browser] workspace 1

exec telegram-desktop
assign [app_id="org.telegram.desktop"] workspace 3



for_window [floating] resize set width 12 px height 3 pc

for_window [app_id="org.telegram.desktop"] floating enable

#### TODO –љ–∞—Б—В—А–Њ–Є—В—М mako

